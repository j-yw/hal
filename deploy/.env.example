# hal-cloud deployment environment variables.
# Copy to .env and fill in actual values.

# Database adapter: "turso" (default) or "postgres"
HAL_CLOUD_DB_ADAPTER=turso

# Turso connection (required when HAL_CLOUD_DB_ADAPTER=turso)
HAL_CLOUD_TURSO_URL=libsql://your-db.turso.io
HAL_CLOUD_TURSO_AUTH_TOKEN=your-turso-auth-token

# Postgres connection (required when HAL_CLOUD_DB_ADAPTER=postgres)
# HAL_CLOUD_POSTGRES_DSN=postgres://user:pass@localhost:5432/hal

# Daytona SDK (worker connects directly via Go SDK)
# Required: API key for Daytona authentication
DAYTONA_API_KEY=your-daytona-api-key
# Optional: API URL (falls back to DAYTONA_SERVER_URL if unset)
DAYTONA_API_URL=https://api.daytona.io
# Optional: Legacy alias for DAYTONA_API_URL (used only when DAYTONA_API_URL is unset)
# DAYTONA_SERVER_URL=https://api.daytona.io
# Optional: Daytona target for sandbox placement
# DAYTONA_TARGET=
