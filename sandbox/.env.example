# Copy this file to sandbox/.env and fill in your values
# docker run --rm -it --env-file sandbox/.env hal-sandbox

# ── Git identity ─────────────────────────────────────────────────────────────
GIT_USER_NAME=j-yw
GIT_USER_EMAIL=32629001+j-yw@users.noreply.github.com

# ── API keys (required for the tools to function) ────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── GitHub auth ──────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...

# ── Tailscale (for SSH from phone) ───────────────────────────────────────────
# Generate at: https://login.tailscale.com/admin/settings/keys
# Use a reusable + ephemeral key so sandboxes auto-register and auto-cleanup
TAILSCALE_AUTHKEY=tskey-auth-...
TAILSCALE_HOSTNAME=hal-sandbox
