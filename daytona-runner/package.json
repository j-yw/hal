{
  "name": "daytona-runner",
  "version": "0.1.0",
  "private": true,
  "description": "Daytona sandbox lifecycle runner service for hal-cloud",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
